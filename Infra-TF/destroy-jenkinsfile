pipeline {
    agent any

    environment {
        TF_ABS_DIR = "/var/lib/jenkins/workspace/tf_test/Infra-TF"
        TF_PLUGIN_TIMEOUT = "300"
    }

    stages {
        stage('Check Terraform State Path') {
            steps {
                sh '''
                echo "Checking Terraform directory:"
                ls -la ${TF_ABS_DIR}

                echo ""
                echo "Checking Terraform state file:"
                ls -la ${TF_ABS_DIR}/terraform.tfstate
                '''
            }
        }

        stage('Check AWS Identity') {
            steps {
                sh '''
                echo "Checking AWS identity:"
                aws sts get-caller-identity
                '''
            }
        }

        stage('Terraform Init') {
            steps {
                dir("${TF_ABS_DIR}") {
                    sh '''
                    terraform init
                    '''
                }
            }
        }

        stage('Show Terraform State') {
            steps {
                dir("${TF_ABS_DIR}") {
                    sh '''
                    terraform state list
                    '''
                }
            }
        }

        stage('Manual Destroy Approval') {
            steps {
                input message: 'Are you sure you want to destroy the Terraform-created AWS resources?'
            }
        }

        stage('Terraform Destroy') {
            steps {
                dir("${TF_ABS_DIR}") {
                    sh '''
                    terraform destroy -auto-approve
                    '''
                }
            }
        }

        stage('Verify State After Destroy') {
            steps {
                dir("${TF_ABS_DIR}") {
                    sh '''
                    terraform state list || true
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Terraform destroy pipeline completed successfully.'
        }

        failure {
            echo 'Terraform destroy pipeline failed. Check console output.'
        }
    }
}